import testing ;
import path ;

project
    : requirements
        <cxxstd>11
        <link>static
        <toolset>gcc:<cxxflags>"-Wno-dangling-else -Wno-sign_compare -w"
        <toolset>clang:<cxxflags>"-Wno-delete-non-abstract-non-virtual-dtor -Wno-delete-non-virtual-dtor -Wno-dangling-else -w"
    ;

compile _hpp_compile_attach_test.cpp ../build//headers ;
compile _hpp_compile_attribute_test.cpp ../build//headers ;
compile _hpp_compile_aura_test.cpp ../build//headers ;
compile _hpp_compile_config_test.cpp ../build//headers ;
compile _hpp_compile_emit_test.cpp ../build//headers ;
compile _hpp_compile_meta_test.cpp ../build//headers ;
compile _hpp_compile_event_test.cpp ../build//headers ;
compile _hpp_compile_mute_test.cpp ../build//headers ;
compile _hpp_compile_subscribe_test.cpp ../build//headers ;
compile _hpp_compile_thread_affinity_test.cpp ../build//headers ;
compile _hpp_compile_thread_local_queue_test.cpp ../build//headers : <threading>multi ;

run args_subscribe_test.cpp ../build//aura ;
run attr_test.cpp ../build//aura ;
run emit_stub_test.cpp ../build//headers ;
run emit_test.cpp ../build//aura ;
run mute_emit_test.cpp ../build//aura ;
run mute_test.cpp ../build//aura ;
run release_test.cpp ../build//aura ;
run subscribe_emit_test.cpp ../build//aura ;
run subscription_lifetime_test.cpp ../build//aura ;
run subscription_user_data_test.cpp ../build//aura ;
run weak_store_test.cpp ../build//headers ;

run shutdown1_test.cpp ../build//aura ;
run shutdown2_test.cpp ../build//aura ;
run shutdown3_test.cpp ../build//aura ;
run shutdown4_test.cpp ../build//aura ;
run shutdown5_test.cpp ../build//aura ;
run shutdown6_test.cpp ../build//aura ;
run shutdown7_test.cpp ../build//aura ;
run shutdown8_test.cpp ../build//aura ;
run shutdown9_test.cpp ../build//aura ;

run ct_attr_test.cpp ../build//aura : : : <threading>multi ;
run ct_basic_test.cpp ../build//aura : : : <threading>multi ;

# We disable this on this particular mingw / gcc combination because it has
# bugs in the C++ throad local tear down support.
run ct_lambda_test.cpp ../build//aura : : : <threading>multi <target-os>windows,<toolset-gcc:version>14:<build>no ;

run ct_tlq_lifetime_test.cpp ../build//aura : : : <threading>multi ;
run ct_wait_missed_wakeup_test.cpp ../build//aura : : : <threading>multi ;
run ct_wait_test.cpp ../build//aura : : : <threading>multi ;
