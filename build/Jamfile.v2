project
    : source-location
        ../src
    : requirements
        <cxxstd>11
        <toolset>gcc:<cxxflags>"-Wno-dangling-else -Wno-sign_compare -w"
        <toolset>clang:<cxxflags>"-Wno-delete-non-abstract-non-virtual-dtor -Wno-delete-non-virtual-dtor -Wno-dangling-else -w"
    ;

alias headers : : : : <include>../include ;
obj subscribe : subscribe.cpp headers ;
obj thread_local_queue : thread_local_queue.cpp headers ;
lib aura : subscribe thread_local_queue headers ;
